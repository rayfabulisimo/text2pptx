{
	"version": 1,
	"base_image": "codeocean/miniconda3:25.3.0-3-python3.12.10-ubuntu22.04",
	"post_install": true,
	"options": {
		"registry_host_arg": true,
		"git_ask_pass": true,
		"mount_secrets": true
	},
	"installers": {
		"apt": {
			"packages": [
				{
					"name": "apt-transport-https",
					"version": "2.4.14"
				},
				{
					"name": "curl",
					"version": "7.81.0-1ubuntu1.21"
				},
				{
					"name": "nodejs",
					"version": "20.20.0-1nodesource1"
				},
				{
					"name": "poppler-utils",
					"version": "22.02.0-2ubuntu0.12"
				}
			],
			"install_software_properties_common": true
		},
		"vscode": {
			"packages": [
				{
					"name": "anthropic.claude-code",
					"version": "2.1.7"
				},
				{
					"name": "ms-python.python",
					"version": "2025.14.0"
				},
				{
					"name": "ms-toolsai.jupyter",
					"version": "2025.4.1"
				},
				{
					"name": "reditorsupport.r",
					"version": "2.8.6"
				},
				{
					"name": "saoudrizwan.claude-dev",
					"version": "3.35.1"
				}
			],
			"version": "4.100.3"
		}
	},
	"env_variables": [
		{
			"name": "CLAUDE_CODE_USE_BEDROCK",
			"value": "1"
		},
		{
			"name": "AWS_REGION",
			"value": "us-east-1"
		},
		{
			"name": "DISABLE_PROMPT_CACHING",
			"value": "1"
		},
		{
			"name": "ANTHROPIC_MODEL",
			"value": "us.anthropic.claude-sonnet-4-5-20250929-v1:0"
		},
		{
			"name": "ANTHROPIC_SMALL_FAST_MODEL",
			"value": "us.anthropic.claude-haiku-4-5-20251001-v1:0"
		},
		{
			"name": "CLAUDE_CODE_MAX_OUTPUT_TOKENS",
			"value": "4096"
		},
		{
			"name": "MAX_THINKING_TOKENS",
			"value": "1024"
		}
	]
}